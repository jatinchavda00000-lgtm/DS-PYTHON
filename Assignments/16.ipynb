   "source": [
    "# Count frequencies in a list using a dictionary\n",
    "\n",
    "lst = [1, 1, 1, 5, 5, 3, 1, 3, 3, 1, 4, 4, 4, 2, 2, 2, 2]\n",
    "\n",
    "freq = {}\n",
    "\n",
    "for item in lst:\n",
    "    if item in freq:\n",
    "        freq[item] += 1\n",
    "    else:\n",
    "        freq[item] = 1\n",
    "\n",
    "for key in sorted(freq):\n",
    "    print(key, \":\", freq[key])"
   ]
  }
 ],
