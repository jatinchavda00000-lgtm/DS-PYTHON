   "source": [
    "# Unzip a list of tuples into individual lists\n",
    "\n",
    "tuples_list = [(1, 'a'), (2, 'b'), (3, 'c')]\n",
    "\n",
    "list1, list2 = zip(*tuples_list)\n",
    "\n",
    "print(\"List 1:\", list(list1))\n",
    "print(\"List 2:\", list(list2))"
   ]
  }
