   "source": [
    "# Get a single string by swapping the first two characters\n",
    "\n",
    "str1 = \"abc\"\n",
    "str2 = \"xyz\"\n",
    "\n",
    "new_str1 = str2[:2] + str1[2:]\n",
    "new_str2 = str1[:2] + str2[2:]\n",
    "\n",
    "result = new_str1 + \" \" + new_str2\n",
    "\n",
    "print(result)"
   ]
  }
