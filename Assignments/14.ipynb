    "# Find the highest 3 values in a dictionary\n",
    "\n",
    "d = {'a': 10, 'b': 50, 'c': 30, 'd': 20, 'e': 40}\n",
    "\n",
    "highest = sorted(d.values(), reverse=True)[:3]\n",
    "\n",
    "print(\"Highest 3 values:\", highest)"
