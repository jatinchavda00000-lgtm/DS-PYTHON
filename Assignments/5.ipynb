   "source": [
    "# Add 'ing' or 'ly' to a string\n",
    "\n",
    "s = input(\"Enter a string: \")\n",
    "\n",
    "if len(s) < 3:\n",
    "    print(s)\n",
    "elif s.endswith(\"ing\"):\n",
    "    print(s + \"ly\")\n",
    "else:\n",
    "    print(s + \"ing\")"
   ]
  }
