    "\n",
    "n = 7\n",
    "a, b = 0, 1\n",
    "\n",
    "print(\"First few Fibonacci numbers are\", end=\" \")\n",
    "\n",
    "for i in range(n + 1):\n",
    "    print(a, end=\", \" if i < n else \"\")\n",
    "    a, b = b, a + b"
