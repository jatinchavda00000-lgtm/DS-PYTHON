   "source": [
    "# Replace 'not'...'poor' with 'good'\n",
    "\n",
    "s = input(\"Enter a string: \")\n",
    "\n",
    "not_pos = s.find(\"not\")\n",
    "poor_pos = s.find(\"poor\")\n",
    "\n",
    "if not_pos != -1 and poor_pos != -1 and not_pos < poor_pos:\n",
    "    s = s[:not_pos] + \"good\" + s[poor_pos + 4:]\n",
    "\n",
    "print(s)"
   ]
  }
 ],
